---
import { Image } from 'astro:assets';
import TeycoLogo from '../assets/images/logo_teyco_v3.png';

interface Props {
  title?: string;
}

const { title = "TEYCO" } = Astro.props;

const navItems = [
  { name: "Inicio", url: "/" },
  { name: "Servicios", url: "/servicios" },
  { name: "Paquetes", url: "/paquetes" },
  { name: "Sobre Nosotros", url: "/sobre-nosotros" },
  { name: "Contacto", url: "/contacto" },
];
---

<header id="site-header" class="sticky top-0 z-50 transition-all duration-300">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-3">
    <div class="flex items-center justify-between">

      <!-- Logo -->
      <a href="/" class="flex items-center flex-shrink-0">
        <Image
          src={TeycoLogo}
          alt={title}
          class="h-12 w-auto"
          width={128}
          height={48}
        />
      </a>

      <!-- Desktop Navigation -->
      <nav class="hidden md:flex items-center space-x-8">
        {navItems.map((item) => (
          <a href={item.url} class="nav-link relative font-medium text-sm pb-0.5">
            {item.name}
          </a>
        ))}
      </nav>

      <!-- Desktop CTA -->
      <div class="hidden md:block">
        <a
          href="/contacto"
          class="inline-flex items-center gap-2 px-5 py-2 rounded-full bg-accent-500 hover:bg-accent-400 text-primary-900 font-bold text-sm transition-all duration-300 shadow-[0_0_20px_rgba(0,188,212,0.3)] hover:shadow-[0_0_30px_rgba(0,188,212,0.5)] hover:-translate-y-0.5 active:translate-y-0"
        >
          Solicitar Información
        </a>
      </div>

      <!-- Mobile hamburger -->
      <button id="mobile-menu-button" class="md:hidden focus:outline-none p-1" aria-label="Abrir menú">
        <svg
          id="hamburger-icon"
          xmlns="http://www.w3.org/2000/svg"
          class="h-6 w-6"
          fill="none"
          viewBox="0 0 24 24"
          stroke="currentColor"
        >
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
        </svg>
      </button>
    </div>

    <!-- Mobile Navigation -->
    <div id="mobile-menu" class="md:hidden hidden pt-2">
      <div class="flex flex-col space-y-1 bg-primary-900 rounded-xl p-4 mt-2 border border-primary-700/50">
        {navItems.map((item) => (
          <a
            href={item.url}
            class="text-gray-300 hover:text-white py-2 font-medium transition-colors duration-200 text-sm border-b border-primary-700/40 last:border-0"
          >
            {item.name}
          </a>
        ))}
        <a
          href="/contacto"
          class="inline-flex items-center justify-center gap-2 px-5 py-2.5 rounded-full bg-accent-500 hover:bg-accent-400 text-primary-900 font-bold text-sm transition-all duration-300 shadow-[0_0_20px_rgba(0,188,212,0.3)] mt-3"
        >
          Solicitar Información
        </a>
      </div>
    </div>
  </div>
</header>

<script>
  const header = document.getElementById('site-header');

  const updateHeader = () => {
    if (window.scrollY > 20) {
      header?.classList.add('scrolled');
    } else {
      header?.classList.remove('scrolled');
    }
  };

  window.addEventListener('scroll', updateHeader, { passive: true });
  updateHeader();

  // Mobile menu toggle
  const mobileMenuButton = document.getElementById('mobile-menu-button');
  const mobileMenu = document.getElementById('mobile-menu');

  if (mobileMenuButton && mobileMenu) {
    mobileMenuButton.addEventListener('click', () => {
      mobileMenu.classList.toggle('hidden');
    });
  }
</script>

<style>
  /* ── Estado inicial: fondo claro ── */
  header {
    background: rgba(255, 255, 255, 0.97);
    backdrop-filter: blur(8px);
    border-bottom: 1px solid rgba(0, 0, 0, 0.07);
    box-shadow: 0 1px 12px rgba(0, 0, 0, 0.06);
  }

  /* ── Estado scrolled: glassmorphism oscuro ── */
  header.scrolled {
    background: rgba(26, 35, 126, 0.85);
    backdrop-filter: blur(16px);
    border-bottom: 1px solid rgba(255, 255, 255, 0.08);
    box-shadow: 0 4px 30px rgba(0, 0, 0, 0.3);
  }

  /* ── Nav links: fondo claro ── */
  .nav-link {
    color: #374151;
    transition: color 0.25s ease;
  }
  .nav-link::after {
    content: '';
    position: absolute;
    bottom: -2px;
    left: 0;
    width: 0;
    height: 2px;
    background-color: #00BCD4;
    transition: width 0.3s ease;
  }
  .nav-link:hover {
    color: #1A237E;
  }
  .nav-link:hover::after {
    width: 100%;
  }

  /* ── Nav links: fondo oscuro (scrolled) ── */
  header.scrolled .nav-link {
    color: #d1d5db;
  }
  header.scrolled .nav-link:hover {
    color: #ffffff;
  }

  /* ── Hamburger icon ── */
  #hamburger-icon {
    color: #4b5563;
    transition: color 0.3s ease;
  }
  header.scrolled #hamburger-icon {
    color: #d1d5db;
  }
</style>
