---
const { service } = Astro.props;
import { Image } from 'astro:assets';
---

<div class="group relative bg-white border border-gray-200 hover:border-accent-500/40 rounded-2xl overflow-hidden h-full flex flex-col transition-all duration-300 hover:shadow-[0_0_30px_rgba(0,188,212,0.12)] hover:-translate-y-1">

  <!-- Image -->
  <div class="relative h-56 overflow-hidden bg-primary-900 flex-shrink-0">
    <Image
      src={service.img}
      alt={service.title}
      class="w-full h-full object-cover opacity-90 group-hover:scale-105 transition-transform duration-500"
      width={400}
      height={224}
    />
    <div class="absolute inset-0 bg-gradient-to-t from-primary-900/50 to-transparent"></div>
  </div>

  <!-- Content -->
  <div class="p-6 flex flex-col flex-grow">

    <!-- Title + accent rule -->
    <h3 class="text-xl font-black text-gray-900 mb-1">{service.title}</h3>
    <div class="w-8 h-0.5 bg-gradient-to-r from-accent-500 to-transparent mb-4"></div>

    <p class="text-gray-600 leading-relaxed flex-grow mb-6">{service.description}</p>

    <!-- Features -->
    <ul class="space-y-2 mb-6">
      {service.features.map((feature) => (
        <li class="flex items-center gap-3 pl-3 border-l-2 border-accent-500/30 hover:border-accent-500 transition-colors duration-300">
          <span class="w-1.5 h-1.5 rounded-full bg-accent-500 flex-shrink-0"></span>
          <span class="text-gray-700 text-sm font-medium">{feature}</span>
        </li>
      ))}
    </ul>

    <!-- Link -->
    <a
      href={`/servicios/${service.title.toLowerCase().replace(/\s+/g, '-')}`}
      class="inline-flex items-center gap-1.5 text-accent-500 hover:text-accent-400 font-semibold text-sm transition-colors duration-200 group/link self-start"
    >
      Más detalles
      <svg class="w-4 h-4 transition-transform duration-200 group-hover/link:translate-x-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
      </svg>
    </a>

  </div>
</div>
