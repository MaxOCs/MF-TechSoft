---
export interface Props {
  service: {
    id: number;
    title: string;
    subtitle: string;
    description: string;
    features: string[];
    lottieUrl: string;
    bgColor: string;
  };
  isReversed?: boolean;
}

const { service, isReversed = false } = Astro.props;
---

<div class={`grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-20 items-center ${isReversed ? 'lg:grid-flow-col-dense' : ''}`}>

  <!-- Animation Container -->
  <div class={`${isReversed ? 'lg:col-start-2' : ''} flex justify-center`}>
    <div class="relative lottie-container">
      <!-- Glow layer behind animation -->
      <div class="absolute inset-0 bg-accent-500 opacity-10 blur-3xl rounded-full scale-90 pointer-events-none" aria-hidden="true"></div>
      <dotlottie-wc
        src={service.lottieUrl}
        style="width: 320px; height: 320px;"
        speed="1"
        autoplay
        loop
        class="relative md:w-5/6 md:h-96"
      ></dotlottie-wc>
    </div>
  </div>

  <!-- Content -->
  <div class={`${isReversed ? 'lg:col-start-1 lg:row-start-1' : ''}`}>
    <div class="space-y-6">

      <!-- Eyebrow -->
      <span class="text-accent-500 text-sm font-semibold uppercase tracking-widest">
        0{service.id} — {service.subtitle}
      </span>

      <!-- Title + accent rule -->
      <div>
        <h3 class="text-3xl md:text-4xl font-black text-gray-900 leading-tight">
          {service.title}
        </h3>
        <div class="w-12 h-0.5 bg-gradient-to-r from-accent-500 to-transparent mt-4"></div>
      </div>

      <!-- Description -->
      <p class="text-gray-600 text-lg leading-relaxed">
        {service.description}
      </p>

      <!-- Features -->
      <ul class="space-y-3 pt-2">
        {service.features.map((feature) => (
          <li class="flex items-center gap-3 pl-3 border-l-2 border-accent-500/40 hover:border-accent-500 transition-colors duration-300">
            <span class="w-1.5 h-1.5 rounded-full bg-accent-500 flex-shrink-0"></span>
            <span class="text-gray-700 font-medium">{feature}</span>
          </li>
        ))}
      </ul>

    </div>
  </div>
</div>

<style>
  .lottie-container {
    animation: float 6s ease-in-out infinite;
    transition: transform 0.3s ease;
  }

  .lottie-container:hover {
    transform: translateY(-6px) scale(1.02);
  }

  dotlottie-wc {
    display: block;
    border-radius: 16px;
    overflow: hidden;
    transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  }

  dotlottie-wc:not([loaded]) {
    background-size: 200% 100%;
    animation: shimmer 1.5s infinite;
  }

  @media (max-width: 768px) {
    dotlottie-wc {
      width: 280px !important;
      height: 280px !important;
    }
  }

  @media (min-width: 768px) {
    dotlottie-wc {
      width: 600px !important;
      height: 500px !important;
    }
  }

  @keyframes float {
    0%, 100% { transform: translateY(0px); }
    50% { transform: translateY(-12px); }
  }

  @keyframes shimmer {
    0% { background-position: 200% 0; }
    100% { background-position: -200% 0; }
  }
</style>
