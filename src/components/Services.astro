---
import ServiceItem from '../components/ServiceItem.astro';

const services = [
  {
    id: 1,
    title: "Desarrollo Web",
    subtitle: "Sitios web modernos y responsivos",
    description: "Creamos sitios web a medida con las últimas tecnologías, optimizados para velocidad y conversión. Desde landing pages hasta aplicaciones web complejas.",
    features: ["Landing Pages", "Sitios Corporativos", "Tiendas Online", "Aplicaciones Web"],
    lottieUrl: "https://lottie.host/4f2e6350-1126-41ef-ad6c-798fff7270c1/RoASxoeNzX.lottie",
    bgColor: "from-purple-50 to-blue-50"
  },
  {
    id: 2,
    title: "Mantenimiento Técnico",
    subtitle: "Soporte especializado 24/7",
    description: "Mantenimiento preventivo y correctivo para equipos y redes empresariales. Garantizamos el funcionamiento óptimo de tu infraestructura tecnológica.",
    features: ["Mantenimiento Preventivo", "Soporte Correctivo", "Actualizaciones", "Monitoreo Continuo"],
    lottieUrl: "https://lottie.host/cdd24c72-b7ce-4615-9027-87151d35afca/y56fmwKUZr.lottie",
    bgColor: "from-green-50 to-teal-50"
  },
  {
    id: 3,
    title: "Marketing Digital",
    subtitle: "Estrategias que generan resultados",
    description: "Desarrollamos estrategias digitales integrales para aumentar tu presencia online y generar más leads. Desde SEO hasta campañas publicitarias efectivas.",
    features: ["SEO & SEM", "Redes Sociales", "Email Marketing", "Analytics & Reporting"],
    lottieUrl: "https://lottie.host/be51facd-2f1a-4aa7-b1cc-a73c025f62c9/9KAKKwv89B.lottie",
    bgColor: "from-orange-50 to-pink-50"
  }
];
---

<section id="servicios" class="relative z-0 py-20 lg:py-32 overflow-hidden bg-white">
  <!-- Decorative background blobs -->
  <div class="absolute inset-0 pointer-events-none" aria-hidden="true">
    <div class="absolute top-0 left-1/2 -translate-x-1/2 w-[900px] h-[500px] bg-accent-500 opacity-[0.04] blur-[140px] rounded-full"></div>
    <div class="absolute bottom-0 right-0 w-[600px] h-[400px] bg-purple-600 opacity-[0.04] blur-[120px] rounded-full"></div>
  </div>

  <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">

    <!-- Section Header -->
    <div class="mb-20 lg:mb-28" data-animate>
      <span class="text-accent-500 text-sm font-semibold uppercase tracking-widest mb-3 block">
        — Nuestros Servicios
      </span>
      <h2 class="text-4xl lg:text-5xl font-black text-gray-900 leading-tight max-w-2xl">
        Desde la <span class="text-accent-500">idea</span> inicial
        hasta el producto <span class="text-accent-500">final</span>
      </h2>
      <div class="w-16 h-1 bg-gradient-to-r from-accent-500 to-transparent mt-6 mb-6"></div>
      <p class="text-lg text-gray-600 max-w-2xl leading-relaxed">
        Tu sitio web se construye desde cero, pensado exclusivamente para tu marca y tus objetivos. Diseño personalizado, estructura optimizada y desarrollo responsivo.
      </p>
    </div>

    <!-- Services List -->
    <div class="space-y-24 lg:space-y-32">
      {services.map((service, index) => (
        <div data-animate data-delay={index * 100}>
          <ServiceItem service={service} isReversed={index % 2 === 1} />
          {index < services.length - 1 && (
            <div class="mt-24 lg:mt-32 w-full h-px bg-gradient-to-r from-transparent via-gray-200 to-transparent"></div>
          )}
        </div>
      ))}
    </div>

    <!-- CTA Banner -->
    <div class="mt-32" data-animate>
      <div class="relative overflow-hidden rounded-2xl p-12 md:p-16 text-center border border-accent-500/20 bg-gradient-to-br from-primary-600 to-primary-900/80">
        <!-- Blob decorations -->
        <div class="absolute inset-0 overflow-hidden pointer-events-none" aria-hidden="true">
          <div class="absolute -top-20 -left-20 w-96 h-96 bg-accent-500 rounded-full opacity-10 blur-3xl"></div>
          <div class="absolute -bottom-20 -right-20 w-96 h-96 bg-purple-600 rounded-full opacity-10 blur-3xl"></div>
          <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-64 h-64 bg-accent-500 rounded-full opacity-5 blur-2xl"></div>
        </div>

        <div class="relative">
          <span class="text-accent-500 text-sm font-semibold uppercase tracking-widest mb-4 block">
            — ¿Tienes un proyecto en mente?
          </span>
          <h3 class="text-3xl md:text-4xl font-black text-white mb-4 leading-tight">
            ¿Listo para transformar<br class="hidden sm:block" /> tu negocio?
          </h3>
          <p class="text-gray-400 text-lg mb-10 max-w-xl mx-auto leading-relaxed">
            Contáctanos y descubre cómo nuestras soluciones pueden llevar tu empresa al siguiente nivel.
          </p>
          <a
            href="/contacto"
            class="inline-flex items-center gap-2 px-8 py-4 rounded-full bg-accent-500 hover:bg-accent-400 text-primary-900 font-bold text-base transition-all duration-300 shadow-[0_0_30px_rgba(0,188,212,0.35)] hover:shadow-[0_0_50px_rgba(0,188,212,0.55)] hover:-translate-y-0.5 active:translate-y-0"
          >
            Solicitar Presupuesto
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
            </svg>
          </a>
        </div>
      </div>
    </div>

  </div>
</section>

<script src="https://unpkg.com/@lottiefiles/dotlottie-wc@0.6.2/dist/dotlottie-wc.js" type="module"></script>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          const delay = entry.target.getAttribute('data-delay') || '0';
          setTimeout(() => {
            entry.target.classList.add('animate-in');
          }, parseInt(delay));
          observer.unobserve(entry.target);
        }
      });
    }, { threshold: 0.1 });

    document.querySelectorAll('#servicios [data-animate]').forEach(el => observer.observe(el));
  });
</script>

<style>
  [data-animate] {
    opacity: 0;
    transform: translateY(32px);
    transition: opacity 0.7s ease, transform 0.7s ease;
  }
  [data-animate].animate-in {
    opacity: 1;
    transform: translateY(0);
  }
</style>
