---
import Layout from '../layouts/Layout.astro';
import ServiceCard from '../components/ServiceCard.astro';
import carouselImage2 from '../assets/images/carrusel-2.webp';
import mantenimineto from '../assets/images/mantenimineto.webp';
import carouselImage4 from '../assets/images/carrusel-4.webp';

const services = [
  {
    title: "Desarrollo Web",
    description: "Creación de sitios web a medida con tecnologías modernas y responsive design.",
    img: carouselImage4,
    features: ["Landing Pages", "Sitios Corporativos", "Tiendas Online Ecommerce"]
  },
  {
    title: "Mantenimiento",
    description: "Soporte técnico especializado para equipos y redes empresariales.",
    img: mantenimineto,
    features: ["Preventivo", "Correctivo", "Actualizaciones"]
  },
  {
    title: "Marketing Digital",
    description: "Estrategias digitales para aumentar tu presencia en línea.",
    img: carouselImage2,
    features: ["SEO", "Redes Sociales", "Publicidad Online"]
  }
];
---

<Layout title="Nuestros Servicios | Teyco">

  <section id="servicios" class="relative z-0 py-20 lg:py-32 overflow-hidden bg-white">

    <!-- Decorative background blobs -->
    <div class="absolute inset-0 pointer-events-none" aria-hidden="true">
      <div class="absolute top-0 left-1/2 -translate-x-1/2 w-[900px] h-[500px] bg-accent-500 opacity-5 blur-[140px] rounded-full"></div>
      <div class="absolute bottom-0 left-0 w-[600px] h-[400px] bg-purple-600 opacity-5 blur-[120px] rounded-full"></div>
      <div class="absolute top-1/3 right-0 w-[400px] h-[400px] bg-accent-500 opacity-[0.03] blur-[100px] rounded-full"></div>
    </div>

    <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">

      <!-- Section Header -->
      <div class="text-center mb-16 lg:mb-20" data-animate>
        <span class="text-accent-500 text-sm font-semibold uppercase tracking-widest mb-3 block">
          — Nuestros Servicios
        </span>
        <h2 class="text-4xl lg:text-5xl font-black text-gray-900 leading-tight mb-6">
          Soluciones que <span class="text-accent-500">transforman</span><br class="hidden sm:block" /> tu negocio
        </h2>
        <div class="w-16 h-1 bg-gradient-to-r from-accent-500 to-transparent mx-auto mb-6"></div>
        <p class="text-lg text-gray-600 max-w-2xl mx-auto leading-relaxed">
          Tecnología diseñada para impulsar tu empresa en el mundo digital, con resultados medibles desde el primer día.
        </p>
      </div>

      <!-- Grid de Servicios -->
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        {services.map((service, index) => (
          <div data-animate data-delay={index * 120} class="h-full">
            <ServiceCard service={service} />
          </div>
        ))}
      </div>

      <!-- CTA -->
      <div class="text-center mt-16 lg:mt-20" data-animate data-delay="400">
        <p class="text-gray-600 mb-6 text-lg">¿No encuentras lo que buscas? Hablemos de tu proyecto.</p>
        <a
          href="/contacto"
          class="inline-flex items-center gap-2 px-8 py-4 rounded-full bg-accent-500 hover:bg-accent-400 text-primary-900 font-bold text-base transition-all duration-300 shadow-[0_0_30px_rgba(0,188,212,0.35)] hover:shadow-[0_0_50px_rgba(0,188,212,0.55)] hover:-translate-y-0.5 active:translate-y-0"
        >
          Solicitar Presupuesto
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
          </svg>
        </a>
      </div>

    </div>
  </section>

</Layout>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          const delay = parseInt(entry.target.getAttribute('data-delay') || '0');
          setTimeout(() => {
            entry.target.classList.add('animate-in');
          }, delay);
          observer.unobserve(entry.target);
        }
      });
    }, { threshold: 0.1 });

    document.querySelectorAll('#servicios [data-animate]').forEach(el => observer.observe(el));
  });
</script>

<style>
  [data-animate] {
    opacity: 0;
    transform: translateY(32px);
    transition: opacity 0.7s ease, transform 0.7s ease;
  }
  [data-animate].animate-in {
    opacity: 1;
    transform: translateY(0);
  }
</style>
